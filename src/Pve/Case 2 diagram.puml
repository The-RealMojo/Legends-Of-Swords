@startuml
title UC2 - Enter BattleRoom

actor Player
participant "PvEController" as Controller
participant "Campaign" as Campaign
participant "RoomFactory" as Factory
participant "BattleRoom" as BattleRoom
participant "Party" as Party
participant "Battle" as Battle
participant "Hero/Unit" as Hero
participant "Enemy/Unit" as Enemy

Player -> Controller : startCampaign(heroes)
Controller -> Campaign : start()
Campaign -> Factory : createRoom(currentRoom, party.getTotalLevel())
Factory -> BattleRoom : return BattleRoom
Campaign -> BattleRoom : execute(party)
BattleRoom -> Party : getHeroes()
BattleRoom -> BattleRoom : generateEnemies(party)
BattleRoom -> Battle : new Battle(heroes, enemies)
Battle -> Battle : startBattle()
Battle -> Hero : attack()/useSkill()
Battle -> Enemy : attack()/useSkill()
Battle -> Battle : repeat until one side defeated
Battle -> BattleRoom : battle ends
BattleRoom -> Campaign : return
@enduml